# Plugin
PLUGIN_SLUG=my-plugin

# Database
MYSQL_ROOT_PASSWORD=password
MYSQL_DATABASE=wordpress
MYSQL_USER=wordpress
MYSQL_PASSWORD=password

# - WP Environment Development
WORDPRESS_DB_HOST=mysql
WORDPRESS_DB_USER=wordpress
WORDPRESS_DB_PASSWORD=password
WORDPRESS_DB_NAME=wordpress
WORDPRESS_DEBUG=true

# - WP Environment PHPUnit Testing
TEST_WORDPRESS_DB_NAME=test_wordpress
TEST_WORDPRESS_DB_USER=wordpress
TEST_WORDPRESS_DB_PASSWORD=password
TEST_WORDPRESS_DB_HOST=mysql
TEST_WORDPRESS_SKIP_DATABASE=true